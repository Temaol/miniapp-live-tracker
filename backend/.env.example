# ── Required ──────────────────────────────────────────────────────────────────
# Get from @BotFather → /newbot
BOT_TOKEN=

# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=

# ── Optional (override only if needed) ────────────────────────────────────────
# Default: SQLite next to the app. On Railway set to sqlite:////data/triproute.db
# DATABASE_URL=sqlite:////data/triproute.db

# Disable Telegram HMAC check — only for local development!
# SKIP_AUTH=true
